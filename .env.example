# -----------------------------------------------------------------------------
# DOCUMIND ELITE: HARDENED ENVIRONMENT CONFIGURATION
# -----------------------------------------------------------------------------

# 1. AUTHENTICATION (Supabase)
# Get these from your Supabase Project Settings -> API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 2. LLM ORCHESTRATION (Backend Only)
# API keys for the AIBroker. NEVER expose these to the frontend.
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIza..."

# 3. DISCOVERY FLEET (Scraping)
FIRECRAWL_API_KEY="fc-..."
TAVILY_API_KEY="tvly-..."

# 4. DATA STORAGE (Multi-Tenant Hub)
# High-Fidelity PostgreSQL (Supabase/Managed)
POSTGRES_URL="postgresql://user:password@host:port/dbname"

# ChromaDB Cloud (Vector Intelligence)
CHROMA_CLOUD_HOST="https://api.trychroma.com"
CHROMA_API_KEY="ck-..."
CHROMA_TENANT="tenant-id"
CHROMA_DATABASE="database-name"
CHROMA_COLLECTION="market_intelligence"

# 5. SECURITY CONFIGURATION
# Production-ready CORS and Redirection
FRONTEND_URL="http://localhost:5173"
ENVIRONMENT="development" # 'production' or 'development'

# 6. TASK QUEUE (Celery + Redis)
REDIS_URL="redis://localhost:6379/0"
